<!DOCTYPE html>
<html>
<head>
<title>JiffyCart</title>
<style>
body {
    font-family: Arial;
    background: #f5f5f5;
    margin: 0;
    padding: 20px;
}
h1 {
    text-align: center;
}
.card {
    width: 250px;
    padding: 20px;
    margin: 20px;
    background: white;
    border-radius: 10px;
    box-shadow: 0 0 5px gray;
    display: inline-block;
}
button {
    background: green;
    color: white;
    padding: 10px;
    border: none;
    cursor: pointer;
}
</style>
</head>
<body>

<h1>Welcome to JiffyCart</h1>

<div class="card">
    <h2>Milk</h2>
    <p>Price: ₹50</p>
    <button>Add to Cart</button>
</div>

<div class="card">
    <h2>Bread</h2>
    <p>Price: ₹40</p>
    <button>Add to Cart</button>
</div>

<div class="card">
    <h2>Rice</h2>
    <p>Price: ₹120</p>
    <button>Add to Cart</button>
</div>

</body>
</html>
